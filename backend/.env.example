# Option 1 (recommended): provide full JDBC URL.
NEON_DB_JDBC_URL=jdbc:postgresql://YOUR_NEON_HOST/YOUR_DB?sslmode=require&channelBinding=require

# Option 2: provide Postgres URI; backend will auto-convert to JDBC.
NEON_DB_URL=postgresql://YOUR_NEON_USERNAME:YOUR_NEON_PASSWORD@YOUR_NEON_HOST/YOUR_DB?sslmode=require&channel_binding=require

NEON_DB_USER=YOUR_NEON_USERNAME
NEON_DB_PASSWORD=YOUR_NEON_PASSWORD
